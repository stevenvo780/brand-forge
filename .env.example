# --- Auth (single-user) ---
ADMIN_USER=admin
ADMIN_PASS=changeme
# Secret used to sign the session cookie. Set a long random value in production.
SESSION_SECRET=dev-secret-change-me

# --- Database (optional in dev) ---
# If unset, the app still boots; brand pages show a "DB not configured" notice.
# DATABASE_URL=postgres://user:pass@localhost:5432/brand_forge

# --- Asset storage (GCS) ---
# Bucket for generated images. ADC creds (compute SA on Cloud Run) are used.
ASSETS_BUCKET=brand-forge-assets
